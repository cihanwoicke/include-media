{
  "title": "include-media",
  "name": "@geeaintvibin/include-media",
  "version": "2.0.0",
  "description": "Simple, elegant and maintainable media queries in Sass",
  "repository": {
    "type": "git",
    "url": "https://github.com/geeaintvibin/include-media.git"
  },
  "main": "index.js",
  "author": {
    "name": "Cihan Woicke",
    "email": "geeaintvibin@gmail.com"
  },
  "bugs": {
    "url": "https://github.com/geeaintvibin/include-media/issues"
  },
  "keywords": [
    "sass",
    "eyeglass-module"
  ],
  "eyeglass": {
    "exports": "eyeglass-exports.js",
    "needs": "*"
  },
  "scripts": {
    "sassTest": "sass --pkg-importer=node test:test/output",
    "test": "npm run lint && mocha",
    "pretest": "npm run build",
    "build": "concat -o dist/_include-media.scss ./banner.txt src/_config.scss src/helpers/*.scss src/plugins/*.scss src/_media.scss",
    "postbuild": "node replace.mjs",
    "lint": "prettier --check src",
    "prepublish": "npm run test",
    "deploy": "gh-pages -d docs",
    "docs": "sassdoc src -c .sassdocrc"
  },
  "sass": "dist/_include-media.scss",
  "license": "MIT",
  "devDependencies": {
    "concat": "^1.0.3",
    "gh-pages": "^6.3.0",
    "mocha": "^11.7.5",
    "pre-commit": "^1.2.2",
    "prettier": "^3.8.1",
    "replace-in-file": "^8.4.0",
    "sass": "^1.101.0",
    "sass-true": "^10.1.0",
    "sassdoc": "^2.7.4"
  },
  "exports": {
    "sass": "./dist/_include-media.scss",
    "default": "./dist/_include-media.scss"
  },
  "pre-commit": [
    "lint"
  ],
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b"
}
